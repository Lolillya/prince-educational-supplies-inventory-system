// -----------------------------------------------------------------------------------------

model Location {
  location_Id      Int                @id @unique @default(autoincrement())
  address_Line     String
  city             String
  State            String
  Country          String
  postal_Code      Int
  Personal_Details Personal_Details[]
}

model Personal_Details {
  Personal_Details_Id String           @id @unique @default(uuid())
  firstName           String
  lastName            String
  contact             Int?
  company             String
  Location            Location?        @relation(fields: [location_Id], references: [location_Id])
  location_Id         Int?
  Notes               String
  Admin               Admin[]
  Employee            Employee[]
  Customer            Customer[]
  Supplier            Supplier[]
  Authentication      Authentication[]
}

model Role {
  role_Id Int @id @unique @default(autoincrement())

  Role_name Roles

  Admin    Admin[]
  Employee Employee[]
  Customer Customer[]
  Supplier Supplier[]
}

model Admin {
  admin_Id            Int              @id @unique @default(autoincrement())
  Personal_Details    Personal_Details @relation(fields: [personal_Details_Id], references: [Personal_Details_Id])
  personal_Details_Id String           @unique
  Role                Role             @relation(fields: [role_Id], references: [role_Id])
  role_Id             Int
}

model Employee {
  employee_Id         Int              @id @unique @default(autoincrement())
  Personal_Details    Personal_Details @relation(fields: [personal_Details_Id], references: [Personal_Details_Id])
  personal_Details_Id String
  Role                Role             @relation(fields: [role_Id], references: [role_Id])
  role_Id             Int
}

model Customer {
  customer_Id         Int              @id @unique @default(autoincrement())
  Personal_Details    Personal_Details @relation(fields: [personal_Details_Id], references: [Personal_Details_Id])
  personal_Details_Id String
  Role                Role             @relation(fields: [role_Id], references: [role_Id])
  role_Id             Int
}

model Supplier {
  supplier_Id         Int              @id @unique @default(autoincrement())
  Personal_Details    Personal_Details @relation(fields: [personal_Details_Id], references: [Personal_Details_Id])
  personal_Details_Id String
  Role                Role             @relation(fields: [role_Id], references: [role_Id])
  role_Id             Int
}

model Authentication {
  Authentication_Id   String           @id @unique @default(uuid())
  Personal_Details    Personal_Details @relation(fields: [personal_Details_Id], references: [Personal_Details_Id])
  personal_Details_Id String
  username            String           @unique
  password            String
}

enum Roles {
  ADMIN
  EMPLOYEE
}

