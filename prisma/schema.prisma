generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Location {
  location_id      Int                @id @default(autoincrement())
  address_line     String?
  city             String?
  region           String?
  country          String?
  postal_code      String?
  personal_details Personal_Details[]
}

model Personal_Details {
  personal_details_id String               @id @default(uuid())
  first_name          String?
  last_name           String?
  contact             String?
  email               String?
  company             String?
  term                Int?
  notes               String?
  location_id         Int?
  auth                Authentication?
  Authentication_Log  Authentication_Log[]
  location            Location?            @relation(fields: [location_id], references: [location_id], onDelete: Cascade)
  User_Role           User_Role?
  Batch               Batch[]
  Inventory           Inventory[]
}

model Role {
  role_Id   Int         @id @unique @default(autoincrement())
  Role_name Roles
  User_Role User_Role[]
}

model User_Role {
  id                                      String           @id @default(uuid())
  Personal_Details_Id                     String           @unique
  role_Id                                 Int
  emoji                                   String           @default("🄿")
  Favorite_Favorite_contact_idToUser_Role Favorite[]       @relation("Favorite_contact_idToUser_Role")
  Favorite_Favorite_user_idToUser_Role    Favorite[]       @relation("Favorite_user_idToUser_Role")
  History_Log                             History_Log[]
  Inventory_Log                           Inventory_Log[]
  customerInvoices                        Invoice[]        @relation("CustomerRelation")
  clerkInvoices                           Invoice[]        @relation("InvoiceClerkRelation")
  Invoice                                 Invoice[]
  Pin                                     Pin[]
  SupplierUnit                            SupplierUnit[]
  Personal_Details                        Personal_Details @relation(fields: [Personal_Details_Id], references: [personal_details_id], onDelete: Cascade)
  Role                                    Role             @relation(fields: [role_Id], references: [role_Id])
}

model Authentication {
  authentication_id   Int              @id @default(autoincrement())
  personal_details_id String           @unique
  username            String           @unique
  password            String
  personal_details    Personal_Details @relation(fields: [personal_details_id], references: [personal_details_id])
}

model Authentication_Log {
  log_id              Int              @id @default(autoincrement())
  personal_details_id String
  action              String
  timestamp           DateTime         @default(now())
  personal_details    Personal_Details @relation(fields: [personal_details_id], references: [personal_details_id])
}

model Brand {
  brand_id   Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  items      Item[]
}

model Category {
  category_id Int      @id @default(autoincrement())
  name        String   @unique
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  items       Item[]
}

model Unit {
  unit_id             Int              @id @default(autoincrement())
  name                String           @unique
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  conversionRatesFrom ConversionRate[] @relation("FromUnit")
  conversionRatesTo   ConversionRate[] @relation("ToUnit")
  Line_Item           Line_Item[]
  SupplierUnit        SupplierUnit[]
}

model Item {
  item_id       Int             @id @default(autoincrement())
  name          String
  brand_id      Int
  category_id   Int
  description   String?
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  discount_id   Int?
  Inventory_Log Inventory_Log[]
  brand         Brand           @relation(fields: [brand_id], references: [brand_id])
  category      Category        @relation(fields: [category_id], references: [category_id])
  discount      Discount?       @relation(fields: [discount_id], references: [discount_id], onDelete: Cascade)
  variants      Variant[]
}

model Variant {
  variant_id   Int            @id @default(autoincrement())
  item_id      Int
  name         String
  discount_id  Int?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  description  String?
  BatchVariant BatchVariant[]
  Favorite     Favorite[]
  inventory    Inventory[]
  LineItem     Line_Item[]
  StockLevel   StockLevel?
  discount     Discount?      @relation(fields: [discount_id], references: [discount_id], onDelete: Cascade)
  item         Item           @relation(fields: [item_id], references: [item_id], onDelete: Cascade)
}

model Batch {
  batch_id         Int              @id @default(autoincrement())
  batch_number     Int              @unique @default(autoincrement())
  quantity         Int
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  notes            String?
  restock_clerk    String
  Personal_Details Personal_Details @relation(fields: [restock_clerk], references: [personal_details_id])
  batchVariants    BatchVariant[]
  Pin              Pin[]
}

model BatchVariant {
  batch_variant_id Int            @id @default(autoincrement())
  batch_id         Int
  variant_id       Int
  quantity         Int
  batch            Batch          @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  variant          Variant        @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)
  SupplierUnit     SupplierUnit[]
}

model SupplierUnit {
  supplier_unit_id  Int              @id @default(autoincrement())
  batch_variant_id  Int
  supplier_id       String
  unit_id           Int
  price             Float
  quantity_per_unit Int
  total_quantity    Int
  discount_id       Int?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  ConversionRate    ConversionRate[]
  batchVariant      BatchVariant     @relation(fields: [batch_variant_id], references: [batch_variant_id], onDelete: Cascade)
  discount          Discount?        @relation(fields: [discount_id], references: [discount_id], onDelete: Cascade)
  supplier          User_Role        @relation(fields: [supplier_id], references: [id])
  unit              Unit             @relation(fields: [unit_id], references: [unit_id])
}

model ConversionRate {
  conversion_id    Int          @id @default(autoincrement())
  supplier_unit_id Int
  from_unit_id     Int
  to_unit_id       Int
  conversion_rate  Float
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  fromUnit         Unit         @relation("FromUnit", fields: [from_unit_id], references: [unit_id])
  supplierUnit     SupplierUnit @relation(fields: [supplier_unit_id], references: [supplier_unit_id], onDelete: Cascade)
  toUnit           Unit         @relation("ToUnit", fields: [to_unit_id], references: [unit_id])
}

model Inventory {
  inventory_id     Int              @id @default(autoincrement())
  variant_id       Int
  inventory_number Int              @unique @default(autoincrement())
  quantity         Int
  inventory_clerk  String
  Personal_Details Personal_Details @relation(fields: [inventory_clerk], references: [personal_details_id])
  last_updated     DateTime         @default(now())
  variant          Variant          @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)
}

model StockLevel {
  stock_level_id         Int       @id @default(autoincrement())
  variant_id             Int       @unique
  low_stock              Int
  very_low_stock         Int
  restock_alert          Boolean   @default(false)
  last_notification_sent DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  variant                Variant   @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)
}

model Discount {
  discount_id   Int            @id @default(autoincrement())
  discount_type String
  value         Float
  applies_to    String
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  variant_id    Int?
  unit_id       Int?
  item_id       Int?
  Item          Item[]
  SupplierUnit  SupplierUnit[]
  Variant       Variant[]
}

model Inventory_Log {
  log_id    Int       @id @default(autoincrement())
  item_id   Int
  action    String
  old_data  Json?
  new_data  Json?
  user_id   String
  timestamp DateTime  @default(now())
  item      Item      @relation(fields: [item_id], references: [item_id], onDelete: Cascade)
  user      User_Role @relation(fields: [user_id], references: [Personal_Details_Id])
}

model Invoice {
  invoice_id      Int           @id @default(autoincrement())
  invoice_number  Int           @unique @default(autoincrement())
  customer_id     String
  invoice_clerk   String
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  total_amount    Float         @default(0.0)
  discount        Float?
  status          String
  payment_term_id Int
  notes           String?
  user_RoleId     String?
  customer        User_Role     @relation("CustomerRelation", fields: [customer_id], references: [Personal_Details_Id], onDelete: Cascade)
  invoiceClerk    User_Role     @relation("InvoiceClerkRelation", fields: [invoice_clerk], references: [Personal_Details_Id])
  payment_term    Payment_Term  @relation(fields: [payment_term_id], references: [payment_term_id])
  User_Role       User_Role?    @relation(fields: [user_RoleId], references: [id], onDelete: Cascade)
  line_items      Line_Item[]
  Payment         Payment[]
  payment_logs    Payment_Log[]
  Pin             Pin[]
}

model Line_Item {
  line_item_id Int      @id @default(autoincrement())
  invoice_id   Int
  variant_id   Int
  unit_id      Int
  quantity     Int
  unit_price   Float
  total_price  Float
  created_at   DateTime @default(now())
  discount     Int      @default(0)
  sub_total    Float?
  invoice      Invoice  @relation(fields: [invoice_id], references: [invoice_id], onDelete: Cascade)
  unit         Unit     @relation(fields: [unit_id], references: [unit_id])
  variant      Variant  @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)
}

model Payment_Term {
  payment_term_id Int       @id @default(autoincrement())
  term_name       String    @unique
  description     String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  invoices        Invoice[]
}

model Payment {
  payment_id     Int           @id @default(autoincrement())
  invoice_id     Int
  amount         Float
  payment_date   DateTime      @default(now())
  payment_method String
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  invoice        Invoice       @relation(fields: [invoice_id], references: [invoice_id], onDelete: Cascade)
  PaymentLog     Payment_Log[]
}

model Payment_Log {
  payment_log_id Int      @id @default(autoincrement())
  invoice_id     Int
  payment_id     Int
  status         String
  timestamp      DateTime @default(now())
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  invoice        Invoice  @relation(fields: [invoice_id], references: [invoice_id])
  payment        Payment  @relation(fields: [payment_id], references: [payment_id])
}

model History_Log {
  history_log_id Int        @id @default(autoincrement())
  action         String
  entity_type    String
  entity_id      Int
  user_id        String?
  timestamp      DateTime   @default(now())
  details        Json?
  user           User_Role? @relation(fields: [user_id], references: [Personal_Details_Id])
}

model Favorite {
  favorite_id                              Int        @id @default(autoincrement())
  user_id                                  String
  created_at                               DateTime   @default(now())
  updated_at                               DateTime
  variant_id                               Int?
  contact_id                               String?
  User_Role_Favorite_contact_idToUser_Role User_Role? @relation("Favorite_contact_idToUser_Role", fields: [contact_id], references: [id])
  User_Role_Favorite_user_idToUser_Role    User_Role  @relation("Favorite_user_idToUser_Role", fields: [user_id], references: [id])
  Variant                                  Variant?   @relation(fields: [variant_id], references: [variant_id])

  @@unique([user_id, contact_id])
  @@unique([user_id, variant_id])
}

model Pin {
  pin_id     Int       @id @default(autoincrement())
  user_id    String
  created_at DateTime  @default(now())
  updated_at DateTime
  invoice_id Int?
  batch_id   Int?
  Batch      Batch?    @relation(fields: [batch_id], references: [batch_id])
  Invoice    Invoice?  @relation(fields: [invoice_id], references: [invoice_id])
  User_Role  User_Role @relation(fields: [user_id], references: [id])

  @@unique([user_id, batch_id])
  @@unique([user_id, invoice_id])
}

