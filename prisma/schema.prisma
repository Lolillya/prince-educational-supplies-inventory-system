enum DiscountType {
  FIXED
  PERCENTAGE
}

model Discount {
  DiscountId Int          @id @default(autoincrement())
  Type       DiscountType
  Amount     Decimal
  ExpiryDate DateTime?
  Invoice    Invoice[]
}

model Invoice {
  InvoiceId   Int      @id @default(autoincrement())
  IssueDate   DateTime @default(now())
  TotalAmount Decimal
  DiscountId  Int?

  discount Discount? @relation(fields: [InvoiceId], references: [DiscountId])
}

