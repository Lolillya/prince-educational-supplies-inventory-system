model Location {
  location_Id      Int                @id @unique @default(autoincrement())
  address_Line     String
  city             String
  State            String
  Country          String
  postal_Code      Int
  Personal_Details Personal_Details[]

model location {
  location_id      Int                @id @default(autoincrement())
  address_line     String? // Nullable
  city             String? // Nullable
  state            String? // Nullable
  country          String? // Nullable
  postal_code      String? // Nullable
  personal_details personal_details[]

}

model personal_details {
  personal_details_id Int       @id @default(autoincrement())
  first_name          String
  last_name           String
  contact             String? // Nullable
  email               String? // Nullable
  company             String? // Nullable
  notes               String? // Nullable
  location_id         Int? // Nullable
  location            location? @relation(fields: [location_id], references: [location_id], onDelete: SetNull)

  admins    admin[]
  employees employee[]
  customers customer[]
  suppliers supplier[]
  auth      authentication?
}

model admin {
  admin_id            Int              @id @default(autoincrement())
  personal_details_id Int
  role_id             Int
  personal_details    personal_details @relation(fields: [personal_details_id], references: [personal_details_id])
  role                role             @relation(fields: [role_id], references: [role_id])

  @@unique([admin_id, personal_details_id])
}

model employee {
  employee_id         Int              @id @default(autoincrement())
  personal_details_id Int
  role_id             Int
  personal_details    personal_details @relation(fields: [personal_details_id], references: [personal_details_id])
  role                role             @relation(fields: [role_id], references: [role_id])

  @@unique([employee_id, personal_details_id])
}

model customer {
  customer_id         Int              @id @default(autoincrement())
  personal_details_id Int
  role_id             Int
  personal_details    personal_details @relation(fields: [personal_details_id], references: [personal_details_id])
  role                role             @relation(fields: [role_id], references: [role_id])

  @@unique([customer_id, personal_details_id])
}

model supplier {
  supplier_id         Int              @id @default(autoincrement())
  personal_details_id Int
  role_id             Int
  personal_details    personal_details @relation(fields: [personal_details_id], references: [personal_details_id])
  role                role             @relation(fields: [role_id], references: [role_id])

  @@unique([supplier_id, personal_details_id])
}

model authentication {
  authentication_id   Int              @id @default(autoincrement())
  personal_details_id Int              @unique
  username            String           @unique
  password            String
  personal_details    personal_details @relation(fields: [personal_details_id], references: [personal_details_id])
}
