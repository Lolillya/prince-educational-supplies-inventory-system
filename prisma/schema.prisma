datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model role {
  role_id   Int        @id @default(autoincrement())
  role_name String     @unique
  admins    admin[]
  employees employee[]
  customers customer[]
  suppliers supplier[]
}


